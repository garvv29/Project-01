#pragma once

#include <iostream>
using namespace std;

class DynamicArray {
private:
    int size_;
    int capacity_;
    int *data;
public:

    DynamicArray(){
        size_ = 0;
        capacity_ = 0;
        data = nullptr;
    }

    void append(int value){
        //if capacity_ 0
        if(capacity_==0)
        {
            resize(1);
        }
        //if full
        if(size_==capacity_)
        {
            resize(capacity_*2);
        }
        //normally
        data[size_++]=value;
    }

    void insert(int value,int index)
    {
        //indexcheck
        if(index<0 || index>size_)
        {
            cout<< "Error - Invalid Index"<<endl;
            return;
        }
        //if capacity_ 0
        if(capacity_==0)
        {
            resize(1);
        }
        //if full
        if(size_==capacity_)
        {
            resize(capacity_*2);
        }
        for(int i=size_;i>index;i--)
        {
            data[i]=data[i-1];
        }
        data[index]=value;
        size_++;
    }

    void remove(int index)
    {
        if(index<0 || index>=size_)
        {
            cout<< "Error - Invalid Index"<<endl;
            return;
        }
        for(int i=index;i<size_-1;i++)
        {
            data[i]=data[i+1];
        }
        size_--;
        if(capacity_>1 && size_<=capacity_/4)
        resize(capacity_/2);
    }
    void resize(int newCapacity)
    {
        if(newCapacity<size_)return;

        int* arr = new int[newCapacity];

        for(int i = 0; i < size_; i++)
        {
            arr[i] = data[i];
        }

        delete[] data;

        data = arr;
        capacity_ = newCapacity;
    }
    //testing purpose
    void print()const
    {
        for(int i=0;i<size_;i++)
        {
            cout<<data[i]<<" ";
        }
    }
};