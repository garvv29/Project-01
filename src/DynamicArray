#pragma once

#include <iostream>
#include <cstdlib>
#include <new>
#include <stdexcept>

template <typename T>
class DynamicArray {
private:
    int size_;
    int capacity_;
    T *data;
//helper methods - 

    //method to manually call destructors for each element in the array
    void destroy(){
        for(int i=0;i<size_;i++)
        {
            (data+i)->~T();
        }
    }

    //internal method to resize the array whenever needed
    void resize(int newcap){
        if(newcap<size_)return;
        //grabs raw memory in void* and then cast it into T* pointer
        T* newData = allocate(newcap);
        int i=0;
        try{
            for(;i<size_;i++)
            {
                //creates new objects using placement new in the memory
                construct(newData+i,data[i]);
            }
        }
        catch(...){
            for(int j=0;j<i;j++)
            {
                 (newData + j)->~T();   
            }
            free(newData);
            throw;
        }
        //destroy old objs
        destroy();
        free(data);
        data=newData;
        capacity_=newcap;
    }

    //method to perform a deepcopy
    void deepcopy(const DynamicArray& other){
        size_=other.size_;
        capacity_=other.capacity_;
        if(capacity_==0)
        {
            data=nullptr;
            return;
        }
        data=allocate(capacity_);
        int i=0;
        try{
            for(;i<size_;i++)
            {
                construct(data+i,other.data[i]);
            }
        }
        catch(...){
            for(int j=0;j<i;j++)
            {
                (data+j)->~T();
            }
            free(data);
            data=nullptr;
            size_=0;
            capacity_=0;
            throw;
        }
    }

    //just to not repeat code in every constructor
    void init(){
        size_=0;
        capacity_=0;
        data=nullptr;
    }

    //function to call malloc and handle bad alloc exceptions as malloc does not throw an error but return a nullptr
    T* allocate(int cap){
        if(cap==0)return nullptr;
        void *rawMemory = malloc(sizeof(T)*cap);
        if(rawMemory==nullptr)throw std::bad_alloc();
        return static_cast<T*> (rawMemory);
    }

    //to construct an obj at the given ptr with the provided value
    void construct(T* ptr,const T& value){
        new(ptr) T(value);
    }

    void destroyobj(T* ptr){
        ptr->~T();
    }

public:
//constructors -

    //constructor
    DynamicArray(){
        init();
    }
    
    //capacity constructor
    DynamicArray(int cap){
        size_=0;
        if(cap>=0)capacity_=cap;
        else capacity_=0;
        if(capacity_>0)
        {
            data = allocate(capacity_);
        }
        else
        {
            data=nullptr;
        }
    }

    //copy constructor to pass an array and make a copy
    DynamicArray(const DynamicArray& other){
        init();
        deepcopy(other);
    }
    
    //helper function for =operator 
    void swap(DynamicArray& other) {
        int ts = size_;
        size_ = other.size_;
        other.size_ = ts;

        // Swap capacities
        int tc = capacity_;
        capacity_ = other.capacity_;
        other.capacity_ = tc;

        // Swap data pointers
        T* temp = data;
        data = other.data;
        other.data = temp;
    }

    //assignment operator to use = operator to deepcopy that object
    DynamicArray& operator=(const DynamicArray&other){
        if(this == &other)return *this;
        DynamicArray temp(other);
        //runs destructors for our old dynamic array when temp goes out of scope
        this->swap(temp);
        return *this;
    }

    //constructor to create a dynamic array from an iterable data structure if passed using begin,end addresses
    template<typename Iterator>
    DynamicArray(Iterator start,Iterator end){
        init();
        for(auto it = start;it!=end;it++)
        {
            append(*it);
        }
    }

    //constructor to create a dynamic array from an iterable data structure if passed directly
    template<typename Ds>
    DynamicArray(const Ds& ds){
        init();
        for(auto it=ds.begin();it!=ds.end();it++)
        {
            append(*it);
        }
    }
    
//methods - 

    //to add an element at the last index
    void append(const T& value){
        if(size_==capacity_)resize(capacity_==0?1:capacity_*2);//resize by 2 if s==c and if c==0 then c==1
        construct(data+size_,value);
        size_++;
    }

    void clear(){
        destroy();
        size_=0;
    }

    //returns number of elements
    int size()const{
        return size_;
    }

    //safe retrieval to elements at the given index
    bool get(int index,T& value)const{
        if(index<0 || index>=size_ )return false;//it does not throw error because get should not cause program to throw exceptions
        value = data[index];
        return true;
    }

    //to modify elements at the given index (parameter const to let Rvalue be passed to it too)
    void set(int index,const T& value){
        if(index<0 || index>=size_ ){
            throw std::out_of_range("DynamicArray: Invalid Index");
            return;
        }
        data[index]=value;
    }

    //to insert an element to the given index
    void insert(int index,const T& value){
        if(index<0 || index>size_ )
        {
            throw std::out_of_range("DynamicArray: Invalid Index");
            return;
        }
        if(size_==capacity_)resize(capacity_==0?1:capacity_*2);
        if(index==size_)
        {
            append(value);
            return;
        }
        //make copy of the last element at size index
        construct(data+size_,data[size_-1]);
        for(int i=size_-1;i>index;i--)
        {
            data[i]=data[i-1];
        }       
        data[index]=value;
        size_++;
    }

    //to remove element from the given index
    void remove(int index){
        if(index<0 || index>=size_ )
        {
            throw std::out_of_range("DynamicArray: Invalid Index");
            return;
        }
        for(int i=index;i<size_-1;i++)
        {
            data[i]=data[i+1];
        }
        destroyobj(data+size);
        size_--;
        if(capacity_>4 && size_<capacity_/4)
        {
            resize(capacity_/2);
        }
    }

    //to check if the array is empty
    bool isEmpty()const{
        return size_==0;
    }

    //preallocate memory if needed without increasing size
    void reserve(int newcap){
        if(newcap<=capacity_)return;
        resize(newcap);
    }

    //to deallocate memory not in use to the size of the array
    void shrinktosize(){
        if(size_==capacity_)return;
        if(size_ == 0)
        {
            destroy();
            free(data);
            data = nullptr;
            capacity_ = 0;
            return;
        }
        resize(size_);
    }

    //access elements using [] & is used to return a reference so using arr[10]=100 would be changeable
    T& operator[](int index){
        return data[index];
    }

    //read only [] when const DA is used so it woudl return value in that case
    const T& operator[](int index)const {
        return data[index];
    }

    //to return the starting address 
    T* begin(){
        return data;
    }
    //const begin - 
    const T* begin()const{
        return data;
    }

    //to return address of the location next of end
    T* end(){
        return data+size_;
    }
    //const end
    const T* end()const{
        return data+size_;
    }

//testing purpose - 
    //returns number if elements that can fit into the array
    int capacity()const{
        return capacity_;
    }
    //prints all the elements in the existing array
    void print()const{
        for(int i=0;i<size_;i++)
        {
            std::cout<<data[i]<<" ";
        }
        std::cout<<std::endl;
    }

    //destructor
    ~DynamicArray(){
        destroy();
        free(data);
        data=nullptr;
        size_=0;
        capacity_=0;
    }
};

